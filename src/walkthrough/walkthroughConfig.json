{
  "experimentName": "Basic Electrical Science Lab",
  "defaultLocale": "en",
  "locales": ["en"],
  "audio": {
    "autoplay": false
  },
  "steps": [
    {
      "id": 1,
      "target": "#experiment-title-board",
      "title": {
        "en": "Experiment Goal"
      },
      "description": {
        "en": "The aim of the experiment is to Study the efficiency of single phase transformer by load test"
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 2,
      "target": "#instruction-button",
      "title": {
        "en": "Instruction Button"
      },
      "description": {
        "en": "The Instructions provide step-by-step guidance on how to perform the simulation"
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 3,
      "target": "#ai-guide-button",
      "title": {
        "en": "AI Guide Button"
      },
      "description": {
        "en": "To use this feature, click on the “AI Guide” button. The AI guide will assist you in performing the simulation accurately at each step."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 4,
      "target": "#check-button",
      "title": {
        "en": "Check Button"
      },
      "description": {
        "en": "The CHECK button verifies all the connections to ensure that they are correct."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 5,
      "target": "#auto-connect-button",
      "title": {
        "en": "Auto Connect Button"
      },
      "description": {
        "en": "The AUTO CONNECT button makes all the connections automatically."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 6,
      "target": "#add-reading-button",
      "title": {
        "en": "Add Button"
      },
      "description": {
        "en": "The ADD button adds the readings to the observation table."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 7,
      "target": "#plot-button",
      "title": {
        "en": "Plot Button"
      },
      "description": {
        "en": "The PLOT button helps visualise the readings through a graph."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 8,
      "target": "#reset-button",
      "title": {
        "en": "Reset Button"
      },
      "description": {
        "en": " The RESET button refresh the simulation to its initial state for a fresh start. "
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 9,
      "target": "#print-button",
      "title": {
        "en": "Print Button"
      },
      "description": {
        "en": " The PRINT button allows you to print the simulation. "
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 10,
      "target": "#power-supply",
      "title": {
        "en": "MCB"
      },
      "description": {
        "en": "The MCB turns the verified circuit ON or OFF. It should be turned ON only after the connections are checked."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 11,
      "target": "#voltmeter-meter",
      "title": {
        "en": "Upper Voltmeter"
      },
      "description": {
        "en": "This meter displays the primary-side voltage applied through the autotransformer."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 12,
      "target": "#ammeter-meter",
      "title": {
        "en": "A1 Ammeter"
      },
      "description": {
        "en": "This meter shows the primary-side current for the current load condition."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 13,
      "target": "#wattmeter-meter",
      "title": {
        "en": "Wattmeter"
      },
      "description": {
        "en": "The wattmeter displays the input power used for the observation table."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 14,
      "target": "#autotransformer-device",
      "title": {
        "en": "Autotransformer"
      },
      "description": {
        "en": "Click the autotransformer knob after the MCB is ON to set the primary voltage to 230 V."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 15,
      "target": "#transformer-device",
      "title": {
        "en": "Transformer"
      },
      "description": {
        "en": "This transformer is the device under test. The load test compares primary input and secondary output readings."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 16,
      "target": "#lamp-load",
      "title": {
        "en": "Lamp Load"
      },
      "description": {
        "en": "This complete lamp-load section is enabled step by step during the load test."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 17,
      "target": "#V2",
      "title": {
        "en": "Lower Voltmeter"
      },
      "description": {
        "en": "This meter shows the transformer secondary voltage as the load changes."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 18,
      "target": "#A2",
      "title": {
        "en": "A2 Ammeter"
      },
      "description": {
        "en": "This meter shows the transformer secondary current for the active lamp-load level."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 19,
      "target": "#observation-table-panel",
      "title": {
        "en": "Observation Table"
      },
      "description": {
        "en": "Every ADD action records one row here. Add the no-load row first, then one row after each lamp-load switch."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 20,
      "target": "#generate-report-button",
      "title": {
        "en": "Generate Report Button"
      },
      "description": {
        "en": "After all readings are recorded and the graph is plotted, use this button to generate the report."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 21,
      "target": "#graph-panel",
      "title": {
        "en": "Observation Graph"
      },
      "description": {
        "en": "The walkthrough ends here. After all readings are recorded, the graph displays the plotted results."
      },
      "audio": "#",
      "placement": "top"
    }
  ]
}
